{
  "include": [
    "~/.config/waybar/modules/network.jsonc",
    "~/.config/waybar/modules/cpu.jsonc",
    "~/.config/waybar/modules/memory.jsonc",
{{- if ne .chezmoi.hostname "home" }}
    "~/.config/waybar/modules/backlight.jsonc",
{{- end }}
    "~/.config/waybar/modules/wireplumber.jsonc",
    "~/.config/waybar/modules/divider.jsonc",
    "~/.config/waybar/modules/language.jsonc",
    "~/.config/waybar/modules/workspaces.jsonc",
    "~/.config/waybar/modules/power.jsonc",
    "~/.config/waybar/modules/clock.jsonc",
    "~/.config/waybar/modules/idle-toggle.jsonc",
  ],
  "layer": "top",
  "reload_style_on_change": true,
  "height": 40,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": [
    "custom/network",
    "custom/divider",
    "cpu",
    "custom/divider",
    "memory",
    "custom/divider",
    "wireplumber",
    "custom/divider",
{{- if ne .chezmoi.hostname "home" }}
    "backlight",
    "custom/divider",
{{- end }}
    "hyprland/language",
    "custom/divider",
    "custom/power",
    "custom/divider",
    "custom/idle-toggle",
  ],
}
