{
  "layer": "top",
  "reload_style_on_change": true,
  "height": 40,
  "modules-left": [
    "hyprland/workspaces",
  ],
  "modules-right": [
    "battery",
    "clock"
  ],
  "battery": {
    "format": "{capacity}% <span font_size='24pt' rise='-4096'>{icon}</span>",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format-icons": [
      "",
      "",
      "",
      "",
      ""
    ]
  },
  "clock": {
    "format-alt": "{:%a, %d. %b  %H:%M}"
  }
}
