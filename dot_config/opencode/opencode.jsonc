{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "deny",
      "*nuget.conf*": "deny",
      "*npmrc*": "deny"
    }
  },
  // https://github.com/mohak34/opencode-notifier
  "plugin": ["@mohak34/opencode-notifier@latest"]
}
