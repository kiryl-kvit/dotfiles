#!/usr/bin/env bash
#
# battery-watch — sends notifications when battery reaches warning/critical levels.
# Runs only under Hyprland (launched via exec-once in integrations.conf).
#

BATT_DIR=/sys/class/power_supply
BATTERY=

for candidate in "$BATT_DIR"/BAT* "$BATT_DIR"/BATT*; do
    if [[ -f "$candidate/capacity" && -f "$candidate/status" ]]; then
        BATTERY=$candidate
        break
    fi
done

if [[ -z "$BATTERY" ]]; then
    exit 0
fi

WARN_THRESHOLD=30
CRIT_THRESHOLD=15
SOUND_DIR="$HOME/.config/hypr/sounds"

play_alert_sound() {
    local sound_file=$1

    [[ -f "$sound_file" ]] || return 0

    if command -v paplay >/dev/null 2>&1; then
        paplay --volume=65536 "$sound_file" >/dev/null 2>&1 &
    elif command -v aplay >/dev/null 2>&1; then
        aplay "$sound_file" >/dev/null 2>&1 &
    elif command -v mpv >/dev/null 2>&1; then
        mpv --no-video --no-terminal --script-opts=autoload-disabled=yes --volume=100 "$sound_file" >/dev/null 2>&1 &
    elif command -v ffplay >/dev/null 2>&1; then
        ffplay -nodisp -autoexit -loglevel quiet -volume 100 "$sound_file" >/dev/null 2>&1 &
    fi
}

# Track which notifications have already been sent to avoid repeats.
# Reset when the battery starts charging.
warned=0
critted=0

while true; do
    capacity=$(cat "$BATTERY/capacity" 2>/dev/null)
    status=$(cat "$BATTERY/status" 2>/dev/null)

    if [[ "$status" == "Charging" || "$status" == "Full" ]]; then
        # Reset flags once plugged in so warnings fire again next discharge cycle
        warned=0
        critted=0
    elif [[ "$status" == "Discharging" && -n "$capacity" ]]; then
        if (( capacity <= CRIT_THRESHOLD && critted == 0 )); then
            notify-send \
                --urgency=critical \
                --icon=battery-caution \
                --app-name="Battery" \
                --hint=string:sound-name:battery-caution \
                "Battery Critical" \
                "Battery at ${capacity}%. Plug in now."
            play_alert_sound "$SOUND_DIR/battery-critical.wav"
            critted=1
            warned=1   # suppress the warning-level notice too
        elif (( capacity <= WARN_THRESHOLD && warned == 0 )); then
            notify-send \
                --urgency=normal \
                --icon=battery-low \
                --app-name="Battery" \
                --hint=string:sound-name:battery-low \
                "Battery Low" \
                "Battery at ${capacity}%. Consider plugging in."
            play_alert_sound "$SOUND_DIR/battery-low.wav"
            warned=1
        fi
    fi

    sleep 60
done
